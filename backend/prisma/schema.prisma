generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  canLead  Boolean  @default(false)
  members  Member[]
}

model Group {
  id      Int      @id @default(autoincrement())
  name    String
  members Member[]
}

model Member {
  id          Int              @id @default(autoincrement())
  name        String
  gender      String
  active      Boolean          @default(true)
  groupId     Int?
  group       Group?           @relation(fields: [groupId], references: [id])
  roleId      Int?
  role        Role?            @relation(fields: [roleId], references: [id])
  assignments AssignmentDone[]
  createdAt   DateTime         @default(now())
}

model Week {
  id              Int                  @id @default(autoincrement())
  startDate       DateTime             @unique
  assignments     AssignmentDone[]
  weekTypes       WeekAssignmentType[]
}

model AssignmentType {
  id             Int                  @id @default(autoincrement())
  name           String               @unique
  gender         String
  section        String
  order          Int
  requiresHelper Boolean              @default(false)
  assignments    AssignmentDone[]
  weekTypes      WeekAssignmentType[]
}

model AssignmentDone {
  id               Int            @id @default(autoincrement())
  memberId         Int
  assignmentTypeId Int
  weekId           Int
  isHelper         Boolean        @default(false)
  customName       String?
  member           Member         @relation(fields: [memberId], references: [id])
  assignmentType   AssignmentType @relation(fields: [assignmentTypeId], references: [id])
  week             Week           @relation(fields: [weekId], references: [id])

  @@unique([memberId, assignmentTypeId, weekId, isHelper])
}

model WeekAssignmentType {
  id               Int            @id @default(autoincrement())
  weekId           Int
  assignmentTypeId Int
  customName       String?
  week             Week           @relation(fields: [weekId], references: [id])
  assignmentType   AssignmentType @relation(fields: [assignmentTypeId], references: [id])

  @@unique([weekId, assignmentTypeId])
}